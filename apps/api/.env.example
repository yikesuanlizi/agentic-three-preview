# This file is documentation only. The API does not load secrets from project .env files.
# Configure secrets as system environment variables, then restart PowerShell and npm run dev:api.

# PowerShell examples:
# GITEE_API_KEY is only used by embedding/rerank/visual-embedding.
# setx GITEE_API_KEY "your-gitee-api-key"
# ZHIPU_API_KEY is used by the primary GLM coder.
# setx ZHIPU_API_KEY "your-zhipu-api-key"
# setx ARK_API_KEY "your-volc-ark-api-key"

# Optional runtime settings can also be system environment variables:
# setx API_HOST "127.0.0.1"
# setx API_PORT "8787"
# setx RAG_MILVUS_ADDRESS "127.0.0.1:19530"
